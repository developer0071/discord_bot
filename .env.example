# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token

# ─── Regiment configuration ──────────────────────────────────────────────────
# Role given to people IN the regiment (e.g. "Cadet").
REGIMENT_ROLE_ID=your_regiment_role_id
# Role given to people WAITING / not in the regiment (e.g. "Recruit"). Swapped with the
# regiment role automatically. Leave blank to disable the Recruit side of the swap.
RECRUIT_ROLE_ID=your_recruit_role_id
REGIMENT_MAX_SLOTS=20
WELCOME_CHANNEL_ID=your_welcome_channel_id
LOG_CHANNEL_ID=your_log_channel_id

# ─── Chat auto-responder ─────────────────────────────────────────────────────
# Channel the bot watches for "how do I join the regiment?" questions.
CHATTING=your_chatting_channel_id
# Channel it points people to (open a ticket here). Leave blank to use plain "#tickets" text.
TICKETS_CHANNEL_ID=your_tickets_channel_id

# ─── Firebase service account ────────────────────────────────────────────────
# From the service-account JSON you downloaded in the Firebase console.
# Keep FIREBASE_PRIVATE_KEY wrapped in double quotes and keep the literal \n sequences.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
