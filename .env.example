# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token

# ─── Regiment configuration ──────────────────────────────────────────────────
# Role given to people IN the regiment (e.g. "Cadet").
REGIMENT_ROLE_ID=your_regiment_role_id
# Role given to people WAITING / not in the regiment (e.g. "Recruit"). Swapped with the
# regiment role automatically. Leave blank to disable the Recruit side of the swap.
RECRUIT_ROLE_ID=your_recruit_role_id
REGIMENT_MAX_SLOTS=20

# Who can operate the bot (comma-separated role IDs):
#   MANAGE = add + kick + manage slots/panel    ADD = add people only
REGIMENT_MANAGE_ROLE_IDS=role_id_1,role_id_2
REGIMENT_ADD_ROLE_IDS=role_id_3,role_id_4

# ─── Verification ────────────────────────────────────────────────────────────
# Role granted when a member clicks the Verify button (unlocks the rest of the server).
VERIFIED_ROLE_ID=your_verified_role_id
WELCOME_CHANNEL_ID=your_welcome_channel_id
LOG_CHANNEL_ID=your_log_channel_id

# ─── Chat auto-responder ─────────────────────────────────────────────────────
# Channel(s) the bot watches for "how do I join?" and VIP/PS-code questions.
# One ID, or several separated by commas: CHATTING=111,222,333
CHATTING=your_chatting_channel_id
# Channel it points people to (open a ticket here). Leave blank to use plain "#tickets" text.
TICKETS_CHANNEL_ID=your_tickets_channel_id

# ─── Firebase service account ────────────────────────────────────────────────
# From the service-account JSON you downloaded in the Firebase console.
# Keep FIREBASE_PRIVATE_KEY wrapped in double quotes and keep the literal \n sequences.
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# ─── Web dashboard ───────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
# Discord role IDs (comma-separated) allowed to sign in to the dashboard.
HAVE_ACCESS_ROLES=role_id_1,role_id_2
# The dashboard is gated behind "Login with Discord". Only members holding a
# HAVE_ACCESS_ROLES role in your guild can sign in. Until the OAuth vars below are
# set, every /api route rejects requests (the dashboard stays locked).
#
# 1. Create an app at https://discord.com/developers/applications
# 2. Under OAuth2 → Redirects, add this EXACT URL (your public dashboard API):
#       https://your-tunnel-url/auth/discord/callback
DISCORD_CLIENT_ID=your_oauth_client_id
DISCORD_CLIENT_SECRET=your_oauth_client_secret
DISCORD_OAUTH_REDIRECT=https://your-tunnel-url/auth/discord/callback
# Long random string used to sign dashboard session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
DASHBOARD_SESSION_SECRET=generate_a_long_random_string
# The exact origin of your hosted dashboard (e.g. Vercel). Used for CORS and for
# safe post-login redirects. Leave blank if the bot serves the dashboard itself.
DASHBOARD_ORIGIN=https://your-site.vercel.app
